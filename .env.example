# =============================================================================
# QAForge Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ── Security ─────────────────────────────────────────────────────────────────
# REQUIRED: Generate a strong secret for JWT signing
# python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production

# ── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=qaforge_pass
DATABASE_URL=postgresql://qaforge:${DB_PASSWORD}@db:5432/qaforge

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── LLM Providers (at least one required) ────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# ── Default LLM ─────────────────────────────────────────────────────────────
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514

# ── Ports ────────────────────────────────────────────────────────────────────
# Chosen to avoid conflicts with:
#   Orbit:      80 / 5432 / 6379
#   AgentForge: 8080 / 5433 / 6380
FRONTEND_PORT=8090
DB_PORT=5434
REDIS_PORT=6381
CHROMADB_PORT=8001
