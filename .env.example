# =============================================================================
# QAForge — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# REQUIRED: SECRET_KEY + at least one LLM API key
# =============================================================================

# ── Security ─────────────────────────────────────────────────────────────────
# REQUIRED: Generate a strong secret for JWT signing (min 32 chars)
# python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL 16 — change password for production!
DB_PASSWORD=qaforge_pass
DATABASE_URL=postgresql://qaforge:${DB_PASSWORD}@db:5432/qaforge

# ── Redis ────────────────────────────────────────────────────────────────────
# Redis 7 — used for rate limiting and caching
REDIS_URL=redis://redis:6379/0

# ── ChromaDB ─────────────────────────────────────────────────────────────────
# Vector database for knowledge base (RAG)
# These are internal Docker service names — don't change unless customizing
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# ── LLM Providers ───────────────────────────────────────────────────────────
# At least ONE provider key is required for AI test generation.
# Get keys at:
#   Anthropic: https://console.anthropic.com/
#   OpenAI:    https://platform.openai.com/api-keys
#   Groq:      https://console.groq.com/keys (free tier available)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# ── Default LLM ─────────────────────────────────────────────────────────────
# Which provider to use by default
# Options: anthropic | openai | groq | ollama | mock
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514

# Provider-specific model overrides (optional):
# LLM_FAST_MODEL=claude-haiku-4-5-20251001    # For fast operations
# LLM_SMART_MODEL=claude-sonnet-4-5-20250929  # For complex generation

# ── Ollama (Local AI — Free) ────────────────────────────────────────────────
# Install: brew install ollama (or https://ollama.com/download)
# Pull model: ollama pull llama3.2
# Set DEFAULT_LLM_PROVIDER=ollama to use
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Ports ────────────────────────────────────────────────────────────────────
# External ports — chosen to avoid conflicts with co-located services:
#   Orbit:      80 / 5432 / 6379
#   AgentForge: 8080 / 5433 / 6380
FRONTEND_PORT=8080
DB_PORT=5434
REDIS_PORT=6381
CHROMADB_PORT=8001

# ── Agent Bootstrap (Gatekeeper) ─────────────────────────────────────────────
# Set this token to allow AI agents (Claude Code, Codex, etc.) to self-onboard.
# Agents use: qaforge.py setup --project "Name" --token "this-token"
# Scope: can ONLY create projects + get scoped API keys. Cannot delete/admin.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
QAFORGE_BOOTSTRAP_TOKEN=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins (default: * for development)
# Set to specific origins for production
# CORS_ORIGINS=https://qaforge.yourdomain.com

# ── Reltio MCP (for future test execution) ────────────────────────────────
# Reltio MCP Server provides 50+ tools for entity management, matching, etc.
# See: https://github.com/reltio-ai/reltio-mcp-server
# RELTIO_MCP_URL=http://localhost:8000/sse
# RELTIO_CLIENT_ID=your-client-id
# RELTIO_CLIENT_SECRET=your-client-secret
# RELTIO_TENANT=your-tenant-id

# ── Snowflake (for future SQL execution) ──────────────────────────────────
# Used by Data Engineering agent to execute SQL validation queries
# SNOWFLAKE_ACCOUNT=your-account
# SNOWFLAKE_USER=your-user
# SNOWFLAKE_PASSWORD=your-password
# SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# SNOWFLAKE_DATABASE=YOUR_DB
# SNOWFLAKE_SCHEMA=PUBLIC

# ── Databricks (for future SQL execution) ─────────────────────────────────
# Used by Data Engineering agent for target table validation
# DATABRICKS_HOST=your-workspace.cloud.databricks.com
# DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse
# DATABRICKS_TOKEN=your-token

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO          # INFO | DEBUG
# SQL_ECHO=false          # true to log all SQL queries (noisy)
